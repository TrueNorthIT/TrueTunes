APPINSIGHTS_CONNECTION_STRING=

# GitHub PAT for the F2 feedback dialog — needs public_repo scope on TrueNorthIT/TrueTunes
# Put this in renderer/.env (Vite bakes it in at build time)
VITE_GITHUB_PAT=

# Vestaboard Read/Write API key for the office board (Queuedle announcements + leaderboard).
# Read by `server/scripts/deploy.mjs` and passed to ARM as the `vestaboardApiKey` parameter.
# Leave blank to disable Vestaboard messages.
VESTABOARD_API_KEY=
