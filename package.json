{
  "name": "true-tunes-2",
  "version": "1.0.13",
  "description": "Sonos Web Player proxy app",
  "repository": "https://github.com/TrueNorthIT/TrueTunes",
  "author": {
    "name": "True North IT",
    "email": "jpitts@truenorthit.co.uk",
    "url": "https://truenorthit.co.uk"
  },
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsc && node -e \"const fs=require('fs');fs.copyFileSync('src/debug-ws.html','dist/debug-ws.html');fs.copyFileSync('src/debug-http.html','dist/debug-http.html')\"",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "build": "npm run build:main && npm run build:renderer",
    "dev:renderer": "vite --config renderer/vite.config.ts",
    "dev": "npm run build:main && concurrently -k \"npm run dev:renderer\" \"electron .\"",
    "start": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:publish:win": "npm run build && electron-builder --win --publish always",
    "electron:publish:mac": "npm run build && electron-builder --mac --publish always",
    "test": "vitest --config renderer/vitest.config.ts",
    "test:ui": "vitest --config renderer/vitest.config.ts --ui",
    "test:run": "vitest run --config renderer/vitest.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css}\"",
    "typecheck": "tsc --noEmit && tsc --noEmit --project renderer/tsconfig.json"
  },
  "dependencies": {
    "applicationinsights": "^3.14.0",
    "electron-updater": "^6.8.3",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tanstack/react-query": "^5.99.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "concurrently": "^9.2.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.2",
    "liquid-glass-react": "^1.1.1",
    "lucide-react": "^1.8.0",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "build": {
    "appId": "uk.co.truenorthit.truetunes",
    "productName": "True Tunes",
    "copyright": "Copyright © 2026 True North IT",
    "publish": {
      "provider": "github",
      "owner": "TrueNorthIT",
      "repo": "TrueTunes",
      "releaseType": "release"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "renderer/dist/**",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "verifyUpdateCodeSignature": false,
      "signtoolOptions": {
        "publisherName": "True North IT"
      }
    },
    "nsis": {
      "guid": "com.truenorthit.truetunes",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "True Tunes"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png",
      "category": "public.app-category.music"
    }
  }
}
