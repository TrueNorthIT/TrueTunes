  "author": {
    "name": "True North IT",
    "email": "jpitts@truenorthit.co.uk",
    "url": "https://truenorthit.co.uk"
  },
  "scripts": {
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "build": "npm run build:renderer",
    "dev:renderer": "vite --config renderer/vite.config.ts",
    "tauri": "tauri",
    "dev": "tauri dev",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test": "vitest --config renderer/vitest.config.ts",
    "test:ui": "vitest --config renderer/vitest.config.ts --ui",
    "test:run": "vitest run --config renderer/vitest.config.ts",
    "test:coverage": "vitest run --config renderer/vitest.config.ts --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css}\"",
    "typecheck": "tsc --noEmit --project renderer/tsconfig.json"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "dompurify": "^3.4.1",
    "marked": "^18.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tanstack/react-query": "^5.99.0",
    "@tauri-apps/cli": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.2",
    "liquid-glass-react": "^1.1.1",
    "lucide-react": "^1.8.0",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
