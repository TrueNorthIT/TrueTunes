{
  "name": "true-tunes-2",
  "version": "1.0.0",
  "description": "Sonos Web Player proxy app",
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsc && node -e \"const fs=require('fs');fs.copyFileSync('src/debug-ws.html','dist/debug-ws.html');fs.copyFileSync('src/debug-http.html','dist/debug-http.html')\"",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "build": "npm run build:main && npm run build:renderer",
    "dev:renderer": "vite --config renderer/vite.config.ts",
    "dev": "npm run build:main && concurrently \"npm run dev:renderer\" \"electron .\"",
    "start": "npm run build && electron .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,css}\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "liquid-glass-react": "^1.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^28.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  }
}
